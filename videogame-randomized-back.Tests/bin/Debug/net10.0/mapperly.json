{
  "$schema": "https://raw.githubusercontent.com/riok/mapperly/main/docs/mapperly.schema.json",
  "strictNullability": true,
  "throwOnPropertyMappingNullMismatch": true,
  "allowNullPropertyExpander": false,
  "flattenedNamespaces": false,
  "deduplicateNames": true,
  "nameMatchingStrategy": "Name",
  "memberWritersAccessModifier": "public",
  "sourceGeneratedTestsEnabled": false,
  "unmappedMemberHandling": "Ignore",
  "mappings": {
    "ignoreCase": false,
    "deepCloning": {
      "enabled": false
    },
    "enums": {
      "ignoreCase": false
    }
  }
}
