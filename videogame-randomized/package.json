{
  "name": "videogame-randomized",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Random Video Game Generator - A Vue.js app for discovering random games",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.8.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "~10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "prettier": "3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.7"
  }
}
